# Copy to .env and fill in. NEVER commit .env.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# service_role key (Settings -> API). This service WRITES readings/weather
# and bypasses RLS. Keep it server-side only — never ship it to the web app.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAQ v3 API key — https://explore.openaq.org/register
OPENAQ_API_KEY=

# Optional (Phase 9 notification delivery). Leave blank to use the
# development-safe mock email adapter, which logs "would send" and never
# claims a real delivery. SMS/WhatsApp have no credentialed adapter in this
# phase at all (see docs/ROLE_WORKFLOWS.md).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# local | test | staging | production (Phase 10). Tags structured logs and
# system_health rows only — does not change which Supabase project is used
# (SUPABASE_URL above decides that). Defaults to "local" if unset.
ENVIRONMENT=local

# Comma-separated list of origins allowed to call this API (CORS). Defaults
# to the Vite dev/preview ports only (http://localhost:5173,4173) if unset —
# NEVER falls back to "*". A real staging/production deployment MUST set
# this explicitly to its actual deployed frontend domain(s), e.g.:
#   ALLOWED_ORIGINS=https://vayugati.vercel.app,https://staging-vayugati.vercel.app
ALLOWED_ORIGINS=
